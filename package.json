{
  "name": "axsys",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --maxWorkers=1",
    "test:rls": "supabase test db supabase/tests/database",
    "test:e2e": "playwright test",
    "test:e2e:production": "npm run build && playwright test --config=playwright.production.config.ts",
    "test:all": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:rls && npm run test:e2e && npm run build",
    "db:start": "tsx scripts/start-local-supabase.ts",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:env": "tsx scripts/provision-local-env.ts",
    "db:reset": "supabase db reset --local",
    "db:test": "supabase test db",
    "db:lint": "supabase db lint --local --level warning --fail-on warning",
    "db:advisors": "supabase db advisors --local --fail-on warn",
    "db:types": "supabase gen types typescript --local --schema public > src/lib/supabase/database.types.ts",
    "bootstrap:local": "tsx scripts/bootstrap-local.ts",
    "files:start": "docker compose -f docker-compose.files.yml up -d --wait",
    "files:stop": "docker compose -f docker-compose.files.yml down",
    "files:logs": "docker compose -f docker-compose.files.yml logs --tail=100 clamav"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@phosphor-icons/react": "2.1.10",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "file-type": "22.0.1",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "postgres": "3.4.9",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "server-only": "0.0.1",
    "shadcn": "4.13.0",
    "sharp": "0.35.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tus-js-client": "4.3.1",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "24.13.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
